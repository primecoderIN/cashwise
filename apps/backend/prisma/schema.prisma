// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses   Expense[]
  categories Category[]
  groups     ExpenseGroup[]
}

model Category {
  id        String   @id @default(uuid())
  name      String
  color     String
  icon      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]

  @@unique([name, userId])
}

model ExpenseGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  icon        String   @default("folder")
  color       String   @default("#16a34a")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses Expense[]

  @@unique([name, userId])
}

model Expense {
  id     String   @id @default(uuid())
  title  String
  amount Float
  date   DateTime
  notes  String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  groupId String?
  group   ExpenseGroup? @relation(fields: [groupId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
